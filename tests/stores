const request = require('supertest');
const app = require('../app');

require('./setup');

describe('Store Routes', () => {

    test('POST /stores - success', async () => {
        const res = await request(app)
            .post('/stores')
            .send({
                name: 'Test Store',
                address: '123 Test St'
            });

        expect(res.statusCode).toBe(201);
    });

    test('PUT /stores/:id - update success', async () => {
        const store = await request(app)
            .post('/stores')
            .send({
                name: 'Old Name',
                address: '123 St'
            });

        const res = await request(app)
            .put(`/stores/${store.body.id}`)
            .send({ name: 'New Name' });

        expect(res.statusCode).toBe(200);
        expect(res.body.name).toBe('New Name');
    });

    test('DELETE /stores/:id - success', async () => {
        const store = await request(app)
            .post('/stores')
            .send({
                name: 'Delete Me',
                address: '123 St'
            });

        const res = await request(app)
            .delete(`/stores/${store.body.id}`);

        expect(res.statusCode).toBe(204);
    });
});